{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "recommendations.response",
  "type": "object",
  "additionalProperties": false,
  "required": ["recommendations"],
  "properties": {
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["showId", "score"],
        "properties": {
          "showId": {
            "type": "integer"
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "Similarity as a percentage (0-100)."
          }
        }
      }
    }
  }
}
