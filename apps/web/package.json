    "@types/node": "22.20.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "jsdom": "29.1.1",
