ENV=local

# LangSmith (LANGCHAIN_* names also work for tracing)
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=your-key-here
LANGSMITH_PROJECT=recommendation-system-v4

# Service-to-service — same value as apps/web (sent as X-Internal-Api-Key header)
API_INTERNAL_SECRET=change-me-local-dev-secret

# JWKS verification (ES256) — same project URL as web NEXT_PUBLIC_SUPABASE_URL
SUPABASE_URL=https://<project-ref>.supabase.co
